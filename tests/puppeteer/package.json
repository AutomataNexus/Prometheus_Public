{
  "name": "prometheus-puppeteer-tests",
  "version": "0.1.0",
  "private": true,
  "description": "Prometheus Puppeteer tests for PDF report generation, visual regression, chart rendering, and performance",
  "scripts": {
    "test": "jest --config jest.config.json",
    "test:verbose": "jest --config jest.config.json --verbose",
    "test:watch": "jest --config jest.config.json --watch",
    "test:visual": "jest --config jest.config.json --testPathPattern=visual_regression",
    "test:charts": "jest --config jest.config.json --testPathPattern=chart_rendering",
    "test:reports": "jest --config jest.config.json --testPathPattern=multi_page_report",
    "test:perf": "jest --config jest.config.json --testPathPattern=performance"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 60000,
    "testMatch": [
      "**/*.test.js"
    ]
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "pdf-parse": "^1.1.1",
    "pixelmatch": "^5.3.0",
    "pngjs": "^7.0.0",
    "puppeteer": "^23.11.1"
  }
}
